generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

enum UserRole {
    ADMIN
    MEMBER
    VIEWER
}

enum BookingStatus {
    CONFIRMED
    CHECKED_IN
    COMPLETED
    CANCELLED
    NO_SHOW
}

model Department {
    id          Int      @id @default(autoincrement())
    name        String   @unique
    color       String   @db.VarChar(32)
    description String?  @db.VarChar(255)
    active      Boolean  @default(true)
    headId      Int?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    head     User?     @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
    users    User[]    @relation("DepartmentMembers")
    bookings Booking[]
}

model User {
    id           Int      @id @default(autoincrement())
    name         String   @db.VarChar(120)
    email        String   @unique @db.VarChar(190)
    passwordHash String   @db.VarChar(255)
    phone        String?  @db.VarChar(50)
    role         UserRole @default(MEMBER)
    active       Boolean  @default(true)
    avatarColor  String   @default("#6366f1") @db.VarChar(32)
    departmentId Int?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    department        Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
    headedDepartment  Department[] @relation("DepartmentHead")
    organizedBookings Booking[]    @relation("BookingOrganizer")
}

model Room {
    id          Int      @id @default(autoincrement())
    name        String   @unique @db.VarChar(120)
    capacity    Int
    floor       String   @db.VarChar(40)
    color       String   @db.VarChar(32)
    amenities   Json
    description String?  @db.VarChar(255)
    active      Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    bookings Booking[]
}

model Booking {
    id           Int           @id @default(autoincrement())
    roomId       Int
    title        String        @db.VarChar(190)
    bookingDate  DateTime      @db.Date
    startTime    String        @db.VarChar(5)
    endTime      String        @db.VarChar(5)
    organizerId  Int?
    departmentId Int?
    attendees    Int           @default(1)
    status       BookingStatus @default(CONFIRMED)
    checkinCode  String        @unique @db.VarChar(24)
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt

    room       Room        @relation(fields: [roomId], references: [id], onDelete: Restrict)
    organizer  User?       @relation("BookingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
    department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

    @@index([roomId, bookingDate])
    @@index([organizerId])
    @@index([departmentId])
    @@index([status])
}
